# IDE
.idea/
.vscode

# Superpowers brainstorm artifacts
.superpowers/

# Local .terraform directories
**/.terraform/*

# Ignore variables files
*.auto.tfvars

# Ignore override files
*.tfoverride

# Ignore environment-specific files
.envrc

# Ignore CLI configuration files
.terraformrc
terraform.rc

# .tfstate files - NEVER commit state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# keep generated json files out of commits
*.json
# But allow test fixtures
!cmd/ui/frontend/tests/fixtures/*.json
!cmd/ui/frontend/tests/e2e/fixtures/*.json

# Ignore coverage files
coverage.out

# Ignore migration-plan directory
migration-plan/

.ssh/
*.pem

.env
.DS_Store

# Ignore kcp generated files
kcp-scan/
kcp
set_migration_env_vars.sh
kcp-scan*
cluster-credentials.yaml
msk-credentials.yaml

# Added by goreleaser init:
dist/

local/

tmp
*.log
*.log.gz

# local work not to be committed :)
scratch/

# Test environment certificates (generated, excluded by integration-tests/osk-scan/.gitignore)
.worktrees/

# Claude-generated implementation plans (local only, not part of the codebase)
docs/plans/
docs/brainstorms/
docs/ideation/

# MkDocs build output
site/

# Command reference is generated by cmd/gen-docs at docs-build time.
# Published versions live on gh-pages via kcp-release's mike deploy.
docs/assets/command-reference/
