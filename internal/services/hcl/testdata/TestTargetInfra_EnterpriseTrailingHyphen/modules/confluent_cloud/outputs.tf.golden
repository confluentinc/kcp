output "environment_id" {
  value       = confluent_environment.environment.id
  description = "ID of the environment"
  sensitive   = false
}

output "cluster_id" {
  value       = confluent_kafka_cluster.cluster.id
  description = "ID of the Kafka cluster"
  sensitive   = false
}

output "cluster_bootstrap_endpoint" {
  value       = confluent_kafka_cluster.cluster.bootstrap_endpoint
  description = "Bootstrap endpoint of the Kafka cluster"
  sensitive   = false
}

output "cluster_rest_endpoint" {
  value       = confluent_kafka_cluster.cluster.rest_endpoint
  description = "REST endpoint of the Kafka cluster"
  sensitive   = false
}

output "service_account_id" {
  value       = confluent_service_account.app-manager.id
  description = "ID of the service account"
  sensitive   = false
}

output "kafka_api_key_id" {
  value       = confluent_api_key.app-manager-kafka-api-key.id
  description = "ID of the Kafka API key"
  sensitive   = false
}

output "kafka_api_key_secret" {
  value       = confluent_api_key.app-manager-kafka-api-key.secret
  description = "Secret of the Kafka API key"
  sensitive   = true
}

