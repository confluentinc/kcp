resource "confluent_schema_exporter" "kcp_schema_exporter" {
  name = "kcp_schema_exporter"

  schema_registry_cluster {
    # a value is required for the exporter - just using random string
    id = "testcluster"
  }

  rest_endpoint = var.source_schema_registry_url
  credentials {
    key    = var.source_schema_registry_username
    secret = var.source_schema_registry_password
  }

  subjects     = var.subjects
  context_type = "NONE"

  destination_schema_registry_cluster {
    rest_endpoint = var.confluent_cloud_schema_registry_url

    credentials {
      key    = var.confluent_cloud_schema_registry_api_key
      secret = var.confluent_cloud_schema_registry_api_secret
    }
  }
}

