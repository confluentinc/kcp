variable "source_schema_registry_id" {
  type        = string
  description = "ID of the source schema registry"
}

variable "source_schema_registry_url" {
  type        = string
  description = "URL of the source schema registry"
}

variable "source_schema_registry_username" {
  type        = string
  description = "Username for source schema registry authentication"
}

variable "source_schema_registry_password" {
  type        = string
  description = "Password for source schema registry authentication"
  sensitive   = true
}

variable "confluent_cloud_schema_registry_url" {
  type        = string
  description = "URL of the target schema registry (Confluent Cloud)"
}

variable "confluent_cloud_schema_registry_api_key" {
  type        = string
  description = "API key for the target schema registry (Confluent Cloud)"
}

variable "confluent_cloud_schema_registry_api_secret" {
  type        = string
  description = "API secret for the target schema registry (Confluent Cloud)"
  sensitive   = true
}

variable "subjects" {
  type        = list(string)
  description = "List of subjects to export"
}

