output "environment_id" {
  value       = module.confluent_cloud.environment_id
  description = "ID of the environment"
  sensitive   = false
}

output "cluster_id" {
  value       = module.confluent_cloud.cluster_id
  description = "ID of the Kafka cluster"
  sensitive   = false
}

output "cluster_bootstrap_endpoint" {
  value       = module.confluent_cloud.cluster_bootstrap_endpoint
  description = "Bootstrap endpoint of the Kafka cluster"
  sensitive   = false
}

output "cluster_rest_endpoint" {
  value       = module.confluent_cloud.cluster_rest_endpoint
  description = "REST endpoint of the Kafka cluster"
  sensitive   = false
}

output "service_account_id" {
  value       = module.confluent_cloud.service_account_id
  description = "ID of the service account"
  sensitive   = false
}

output "kafka_api_key_id" {
  value       = module.confluent_cloud.kafka_api_key_id
  description = "ID of the Kafka API key"
  sensitive   = false
}

output "kafka_api_key_secret" {
  value       = module.confluent_cloud.kafka_api_key_secret
  description = "Secret of the Kafka API key"
  sensitive   = true
}

output "vpc_endpoint_id" {
  value       = module.private_link.vpc_endpoint_id
  description = "ID of the AWS VPC Endpoint for the Private Link connection"
  sensitive   = false
}

