// Migrated principal: app_user
resource "confluent_service_account" "app_user" {
  display_name = "app_user"
  description  = "Service Account for app_user"

  lifecycle {
    prevent_destroy = false
  }
}

resource "confluent_kafka_acl" "app_user_allow_topic_read_0" {
  kafka_cluster {
    id = var.confluent_cloud_cluster_id
  }

  resource_type = "TOPIC"
  resource_name = "*"
  pattern_type  = "LITERAL"
  principal     = "User:${confluent_service_account.app_user.id}"
  host          = "*"
  operation     = "READ"
  permission    = "ALLOW"
  rest_endpoint = var.confluent_cloud_cluster_rest_endpoint

  credentials {
    key    = var.confluent_cloud_cluster_api_key
    secret = var.confluent_cloud_cluster_api_secret
  }

  lifecycle {
    prevent_destroy = false
  }
}

resource "confluent_kafka_acl" "app_user_allow_group_read_1" {
  kafka_cluster {
    id = var.confluent_cloud_cluster_id
  }

  resource_type = "GROUP"
  resource_name = "my-group"
  pattern_type  = "PREFIXED"
  principal     = "User:${confluent_service_account.app_user.id}"
  host          = "*"
  operation     = "READ"
  permission    = "ALLOW"
  rest_endpoint = var.confluent_cloud_cluster_rest_endpoint

  credentials {
    key    = var.confluent_cloud_cluster_api_key
    secret = var.confluent_cloud_cluster_api_secret
  }

  lifecycle {
    prevent_destroy = false
  }
}

