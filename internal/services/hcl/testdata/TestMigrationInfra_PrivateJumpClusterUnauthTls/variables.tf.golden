variable "confluent_cloud_api_key" {
  type        = string
  description = "Confluent Cloud API Key"
}

variable "confluent_cloud_api_secret" {
  type        = string
  description = "Confluent Cloud API Secret"
  sensitive   = true
}

variable "aws_region" {
  type        = string
  description = "The AWS region"
}

variable "vpc_id" {
  type        = string
  description = "ID of the VPC"
}

variable "jump_cluster_broker_subnet_cidrs" {
  type        = list(string)
  description = "CIDR ranges of the jump cluster broker subnets"
}

variable "jump_cluster_setup_host_subnet_cidr" {
  type        = string
  description = "CIDR block of the jump cluster setup host subnet"
}

variable "existing_private_link_vpce_id" {
  type        = string
  description = "ID of the existing VPC endpoint for the Private Link connection to Confluent Cloud"
}

variable "jump_cluster_instance_type" {
  type        = string
  description = "Instance type of the jump cluster instances."
}

variable "jump_cluster_broker_storage" {
  type        = string
  description = "Storage size of the jump cluster broker instances."
}

variable "confluent_cloud_cluster_id" {
  type        = string
  description = "ID of the Confluent Cloud cluster that data will be migrated to."
}

variable "confluent_cloud_cluster_bootstrap_endpoint" {
  type        = string
  description = "Bootstrap endpoint of the Confluent Cloud cluster that data will be migrated to."
}

variable "confluent_cloud_cluster_rest_endpoint" {
  type        = string
  description = "REST endpoint of the Confluent Cloud cluster that data will be migrated to."
}

variable "confluent_cloud_cluster_api_key" {
  type        = string
  description = "API key of the Confluent Cloud cluster that data will be migrated to."
  sensitive   = true
}

variable "confluent_cloud_cluster_api_secret" {
  type        = string
  description = "API secret of the Confluent Cloud cluster that data will be migrated to."
  sensitive   = true
}

variable "msk_cluster_id" {
  type        = string
  description = "ID of the MSK cluster that data will be migrated to."
}

variable "msk_cluster_bootstrap_brokers" {
  type        = string
  description = "Bootstrap brokers of the MSK cluster that data will be migrated to."
}

variable "cluster_link_name" {
  type        = string
  description = "Name of the cluster links that will be created between MSK and Confluent Cloud through the jump cluster."
}

