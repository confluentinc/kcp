module "networking" {
  source = "./networking"

  providers = {
    aws = aws
  }

  vpc_id                              = var.vpc_id
  jump_cluster_broker_subnet_cidrs    = var.jump_cluster_broker_subnet_cidrs
  jump_cluster_setup_host_subnet_cidr = var.jump_cluster_setup_host_subnet_cidr
  existing_private_link_vpce_id       = var.existing_private_link_vpce_id
}

module "jump_cluster_setup_host" {
  source = "./jump_cluster_setup_host"

  providers = {
    aws = aws
  }

  jump_cluster_setup_host_subnet_id  = module.networking.jump_cluster_setup_host_subnet_id
  jump_cluster_security_group_ids    = module.networking.jump_cluster_security_group_ids
  jump_cluster_ssh_key_pair_name     = module.networking.jump_cluster_ssh_key_pair_name
  jump_cluster_instances_private_dns = module.jump_cluster.jump_cluster_instances_private_dns
  private_key                        = module.networking.private_key

  depends_on = [module.jump_cluster]
}

module "jump_cluster" {
  source = "./jump_cluster"

  providers = {
    aws = aws
  }

  jump_cluster_broker_subnet_ids             = module.networking.jump_cluster_broker_subnet_ids
  jump_cluster_instance_type                 = var.jump_cluster_instance_type
  jump_cluster_security_group_ids            = module.networking.jump_cluster_security_group_ids
  jump_cluster_ssh_key_pair_name             = module.networking.jump_cluster_ssh_key_pair_name
  jump_cluster_broker_storage                = var.jump_cluster_broker_storage
  confluent_cloud_cluster_id                 = var.confluent_cloud_cluster_id
  confluent_cloud_cluster_bootstrap_endpoint = var.confluent_cloud_cluster_bootstrap_endpoint
  confluent_cloud_cluster_rest_endpoint      = var.confluent_cloud_cluster_rest_endpoint
  confluent_cloud_cluster_api_key            = var.confluent_cloud_cluster_api_key
  confluent_cloud_cluster_api_secret         = var.confluent_cloud_cluster_api_secret
  msk_cluster_id                             = var.msk_cluster_id
  msk_cluster_bootstrap_brokers              = var.msk_cluster_bootstrap_brokers
  cluster_link_name                          = var.cluster_link_name
}

