locals {
  basic_auth_credentials = base64encode("${var.confluent_cloud_cluster_api_key}:${var.confluent_cloud_cluster_api_secret}")
}

resource "null_resource" "confluent_cluster_link" {
  triggers = {
    basic_auth_credentials       = local.basic_auth_credentials
    bootstrap_servers            = var.msk_sasl_scram_bootstrap_servers
    destination_cluster_id       = var.target_cluster_id
    link_name                    = var.cluster_link_name
    msk_sasl_scram_password      = var.msk_sasl_scram_password
    msk_sasl_scram_username      = var.msk_sasl_scram_username
    source_cluster_id            = var.msk_cluster_id
    target_cluster_rest_endpoint = var.target_cluster_rest_endpoint
  }

  provisioner "local-exec" {
    command = <<-EOT
    curl --request POST \
  --url '${self.triggers.target_cluster_rest_endpoint}/kafka/v3/clusters/${self.triggers.destination_cluster_id}/links/?link_name=${self.triggers.link_name}' \
  --header 'Authorization: Basic ${self.triggers.basic_auth_credentials}' \
  --header "Content-Type: application/json" \
  --data '{
    "source_cluster_id": "${self.triggers.source_cluster_id}",
    "configs": [
      {
        "name": "bootstrap.servers",
        "value": "${self.triggers.bootstrap_servers}"
      },
      {
        "name": "link.mode",
        "value": "DESTINATION"
      },
      {
        "name": "security.protocol",
        "value": "SASL_SSL"
      },
      {
        "name": "sasl.mechanism",
        "value": "SCRAM-SHA-512"
      },
      {
        "name": "sasl.jaas.config",
        "value": "org.apache.kafka.common.security.scram.ScramLoginModule required username=\"${self.triggers.msk_sasl_scram_username}\" password=\"${self.triggers.msk_sasl_scram_password}\";"
      }
    ]
  }'
    EOT
  }

  provisioner "local-exec" {
    when    = destroy
    command = <<-EOT
    curl --request DELETE \
  --url '${self.triggers.target_cluster_rest_endpoint}/kafka/v3/clusters/${self.triggers.destination_cluster_id}/links/${self.triggers.link_name}' \
  --header 'Authorization: Basic ${self.triggers.basic_auth_credentials}'
    EOT
  }
}

