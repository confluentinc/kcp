data "aws_ami" "amzn_linux_ami" {
  owners      = ["137112412989"]
  most_recent = true

  filter {
    name   = "architecture"
    values = ["x86_64"]
  }
  filter {
    name   = "name"
    values = ["al2023-ami-2023.*-kernel-6.1-x86_64"]
  }
  filter {
    name   = "state"
    values = ["available"]
  }
  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

resource "aws_instance" "external_outbound_cluster_link" {
  ami                         = data.aws_ami.amzn_linux_ami.id
  instance_type               = "t2.medium"
  subnet_id                   = var.subnet_id
  vpc_security_group_ids      = [var.security_group_id]
  associate_public_ip_address = false

  user_data = templatefile("${path.module}/create-external-outbound-cluster-link.tpl",  {
    cluster_link_name                  = var.cluster_link_name
    confluent_cloud_cluster_api_key    = var.confluent_cloud_cluster_api_key
    confluent_cloud_cluster_api_secret = var.confluent_cloud_cluster_api_secret
    msk_cluster_bootstrap_brokers      = var.msk_cluster_bootstrap_servers
    msk_cluster_id                     = var.msk_cluster_id
    msk_sasl_scram_password            = var.msk_sasl_scram_password
    msk_sasl_scram_username            = var.msk_sasl_scram_username
    target_cluster_id                  = var.target_cluster_id
    target_cluster_rest_endpoint       = var.target_cluster_rest_endpoint
  })

  tags = {
    Name = "external_outbound_cluster_link"
  }
}

