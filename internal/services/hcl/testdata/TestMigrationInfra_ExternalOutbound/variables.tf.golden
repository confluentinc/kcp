variable "confluent_cloud_api_key" {
  type        = string
  description = "Confluent Cloud API Key"
}

variable "confluent_cloud_api_secret" {
  type        = string
  description = "Confluent Cloud API Secret"
  sensitive   = true
}

variable "aws_region" {
  type        = string
  description = "The AWS region"
}

variable "aws_vpc_id" {
  type        = string
  description = "VPC ID of the MSK cluster that data will be migrated to."
}

variable "aws_kafka_brokers" {
  type        = list(object({id=string,subnet_id=string,endpoints=list(object({host=string,port=number,ip=string}))}))
  description = "AWS Kafka brokers of the MSK cluster that data will be migrated to."
}

variable "target_environment_id" {
  type        = string
  description = "Target environment ID of the MSK cluster that data will be migrated to."
}

variable "target_cluster_id" {
  type        = string
  description = "Target cluster ID of the MSK cluster that data will be migrated to."
}

variable "subnet_id" {
  type        = string
  description = "The subnet ID where the EC2 instance will be launched."
}

variable "security_group_id" {
  type        = string
  description = "The security group ID to attach to the EC2 instance."
}

variable "target_cluster_api_key" {
  type        = string
  description = "API key of the Confluent Cloud cluster that data will be migrated to."
  sensitive   = true
}

variable "target_cluster_api_secret" {
  type        = string
  description = "API secret of the Confluent Cloud cluster that data will be migrated to."
  sensitive   = true
}

variable "target_cluster_rest_endpoint" {
  type        = string
  description = "REST endpoint of the Confluent Cloud cluster that data will be migrated to."
}

variable "cluster_link_name" {
  type        = string
  description = "Name of the cluster link that will be created between the source and target Confluent Cloud clusters."
}

variable "msk_cluster_id" {
  type        = string
  description = "ID of the source MSK cluster that data will be migrated from."
}

variable "msk_cluster_bootstrap_servers" {
  type        = string
  description = "Bootstrap brokers of the MSK cluster that data will be migrated to."
}

variable "msk_sasl_scram_username" {
  type        = string
  description = "SASL SCRAM username of the source MSK cluster that data will be migrated from."
  sensitive   = true
}

variable "msk_sasl_scram_password" {
  type        = string
  description = "SASL SCRAM password of the source MSK cluster that data will be migrated from."
  sensitive   = true
}

