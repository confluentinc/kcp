data "aws_internet_gateway" "internet_gateway" {
  filter {
    name   = "attachment.vpc-id"
    values = [var.vpc_id]
  }
}

data "aws_availability_zones" "available" {
  state = "available"

  filter {
    name   = "zone-type"
    values = ["availability-zone"]
  }
}

resource "aws_security_group" "security_group" {
  vpc_id = var.vpc_id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  ingress {
    from_port   = 9091
    to_port     = 9091
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 9092
    to_port     = 9092
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 9093
    to_port     = 9093
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 8090
    to_port     = 8090
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 8081
    to_port     = 8081
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_subnet" "jump_cluster_broker_subnets" {
  count = length(var.jump_cluster_broker_subnet_cidrs)

  vpc_id            = var.vpc_id
  availability_zone = data.aws_availability_zones.available.names[count.index % length(data.aws_availability_zones.available.names)]
  cidr_block        = var.jump_cluster_broker_subnet_cidrs[count.index]
}

resource "aws_subnet" "jump_cluster_setup_host_subnet" {
  vpc_id            = var.vpc_id
  availability_zone = data.aws_availability_zones.available.names[0]
  cidr_block        = var.jump_cluster_setup_host_subnet_cidr
}

resource "aws_eip" "nat_eip" {
  domain = "vpc"
}

resource "aws_nat_gateway" "nat_gw" {
  allocation_id = aws_eip.nat_eip.id
  subnet_id     = aws_subnet.jump_cluster_setup_host_subnet.id
}

resource "aws_route_table" "jump_cluster_setup_host_public_rt" {
  vpc_id = var.vpc_id
  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = data.aws_internet_gateway.internet_gateway.id
  }
}

resource "aws_route_table_association" "jump_cluster_setup_host_public_rt_association" {
  subnet_id      = aws_subnet.jump_cluster_setup_host_subnet.id
  route_table_id = aws_route_table.jump_cluster_setup_host_public_rt.id
}

resource "aws_route_table" "private_subnet_rt" {
  vpc_id = var.vpc_id
  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_nat_gateway.nat_gw.id
  }
}

resource "aws_route_table_association" "jump_cluster_broker_route_table_assoc" {
  count = length(aws_subnet.jump_cluster_broker_subnets)

  subnet_id      = aws_subnet.jump_cluster_broker_subnets[count.index].id
  route_table_id = aws_route_table.private_subnet_rt.id
}

data "aws_vpc_endpoint" "existing_vpce" {
  id = var.existing_private_link_vpce_id
}

resource "aws_security_group_rule" "vpce_ingress_from_jump_cluster_80" {
  type                     = "ingress"
  from_port                = 80
  to_port                  = 80
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.security_group.id
  security_group_id        = tolist(data.aws_vpc_endpoint.existing_vpce.security_group_ids)[0]
}

resource "aws_security_group_rule" "vpce_ingress_from_jump_cluster_443" {
  type                     = "ingress"
  from_port                = 443
  to_port                  = 443
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.security_group.id
  security_group_id        = tolist(data.aws_vpc_endpoint.existing_vpce.security_group_ids)[0]
}

resource "aws_security_group_rule" "vpce_ingress_from_jump_cluster_9092" {
  type                     = "ingress"
  from_port                = 9092
  to_port                  = 9092
  protocol                 = "tcp"
  source_security_group_id = aws_security_group.security_group.id
  security_group_id        = tolist(data.aws_vpc_endpoint.existing_vpce.security_group_ids)[0]
}

resource "tls_private_key" "jump_cluster_ssh_key" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "local_file" "jump_cluster_ssh_key_private_key" {
  content         = tls_private_key.jump_cluster_ssh_key.private_key_pem
  filename        = "./.ssh/jump_cluster_ssh_key_private_key_rsa"
  file_permission = "400"
}

resource "local_file" "jump_cluster_ssh_key_public_key" {
  content         = tls_private_key.jump_cluster_ssh_key.public_key_openssh
  filename        = "./.ssh/jump_cluster_ssh_key_public_key.pub"
  file_permission = "400"
}

resource "aws_key_pair" "jump_cluster_ssh_key" {
  key_name   = "jump_cluster_ssh_key_test1"
  public_key = tls_private_key.jump_cluster_ssh_key.public_key_openssh
}

