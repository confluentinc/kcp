module "confluent_cloud" {
  source = "./confluent_cloud"

  providers = {
    confluent = confluent
  }

  aws_region       = var.aws_region
  environment_name = var.environment_name
  cluster_name     = var.cluster_name
  cluster_type     = var.cluster_type
}

module "private_link" {
  source = "./private_link"

  providers = {
    aws       = aws
    confluent = confluent
  }

  aws_region         = var.aws_region
  vpc_id             = var.vpc_id
  subnet_cidr_ranges = var.subnet_cidr_ranges
  environment_id     = module.confluent_cloud.environment_id
}

data "confluent_endpoint" "private_kafka_endpoints" {
  filter {
    environment {
      id = module.confluent_cloud.environment_id
    }
    service    = "KAFKA"
    resource   = module.confluent_cloud.cluster_id
    cloud      = "AWS"
    region     = var.aws_region
    is_private = true
  }

  depends_on = [module.private_link]
}

